{
  "name": "secapi-mcp",
  "version": "0.2.0",
  "description": "Official Model Context Protocol server for secapi.dev — SEC filings, financials, insiders, and institutional holdings as AI-native tools.",
  "type": "module",
  "license": "MIT",
  "author": "SEC API <support@secapi.dev>",
  "homepage": "https://secapi.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/secapi-dev/secapi-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/secapi-dev/secapi-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sec",
    "edgar",
    "filings",
    "financials",
    "secapi",
    "ai",
    "claude",
    "cursor"
  ],
  "bin": {
    "secapi-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && npm publish --provenance --access public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "secapi-node": "^0.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
